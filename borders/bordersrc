#!/bin/bash
# JankyBorders — paints a border around every window so you can see what's
# focused without yabai having to dim everything else.
#
# Active = light red/orange (coral) so the focused window pops.
# Inactive = muted gray so unfocused windows recede.
options=(
    style=round
    width=6.0
    hidpi=on
    active_color=0xffff8c69
    inactive_color=0xff6e6a86
    background_color=0x00000000
    blur_radius=0.0
)
borders "${options[@]}"
